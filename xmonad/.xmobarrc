Config { font = "-*-Fixed-Bold-R-Normal-*-13-*-*-*-*-*-*-*"
       , bgColor = "black"
       , fgColor = "grey"
       , position = TopW L 90
       , commands = [ Run MultiCpu ["-L","3","-H","50","--normal","green","--high","red"] 10
                    , Run Memory ["-t","M: <usedratio>%"] 10
                    , Run Swap ["-t", "S:<usedratio>%"] 10
                    , Run Date "%a %b %_d %l:%M:%S" "date" 10
                    , Run StdinReader
                    , Run CpuFreq["-t", "<cpu0>", "-L", "0", "-H", "2","-l", "lightblue", "-n","white", "-h", "red" ] 50
                    , Run ThermalZone 0 ["-t","<temp>C", "-L", "50", "-H", "70","-l", "lightblue", "-n","white", "-h", "red"] 50
                    , Run DynNetwork [] 10
                    ]
       , sepChar = "%"
       , alignSep = "}{"
       , template = "%StdinReader% }{ %dynnetwork% | %multicpu% (%thermal0%) | %memory%  %swap% | <fc=#ee9a00>%date%</fc> |"
       }
