-- vim: ft=haskell:

Config { font = "-*-Fixed-Bold-R-Normal-*-13-*-*-*-*-*-*-*"
       , bgColor = "black"
       , fgColor = "grey"
       , position = TopW L 90
       , commands = [ Run MultiCpu ["-L","3","-H","50","--normal","green","--high","red"] 10
                    , Run Memory ["-t","M: <usedratio>%"] 10
                    , Run Swap ["-t", "S:<usedratio>%"] 10
                    , Run Date "%a %b %_d %l:%M:%S" "date" 10
                    , Run DateZone "%H%MZ" "us_EN.UTF-8" "UTC" "UTC" 10
                    , Run StdinReader
                    , Run CpuFreq["-t", "<cpu0>", "-L", "0", "-H", "2","-l", "lightblue", "-n","white", "-h", "red" ] 50
                    , Run ThermalZone 0 ["-t","<temp>C", "-L", "50", "-H", "70","-l", "lightblue", "-n","white", "-h", "red"] 50
                    , Run BatteryP ["BAT0"]
                                  ["-t", "<acstatus> <watts>W <left>%/<timeleft>",
                                  "-L", "10", "-H", "80", "-p", "3",
                                  "--",
                                  "-O", "<fc=green>Charging</fc>",
                                  "-o", "",
                                  "-i", "<fc=green>AC IDLE</fc>",
                                  "-L", "-15",
                                  "-H", "-5",
                                  "-l", "red",
                                  "-m", "blue",
                                  "-h", "green"]
                                  50
                    , Run DynNetwork [] 10
                    ]
       , sepChar = "%"
       , alignSep = "}{"
       , template = "%StdinReader% }{ %dynnetwork% | %multicpu% (%thermal0%) | %memory%  %swap% | %battery% | <fc=#ee9a00>%date%</fc>  ( %UTC% )|"
       }
